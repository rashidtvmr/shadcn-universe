exports[`Comprehensive Code Generation Tests > @tanstack/react-form > should generate form for array field 1`] = `
"\\"use client\\";

import { useForm } from \\"@tanstack/react-form\\"
import { ArraySchema } from \\"./schemas\\";
import { XIcon, PlusIcon } from \\"lucide-react\\";
import { Button } from \\"@/registry/ui/button\\";
import {
    Field,
    FieldError,
    FieldGroup,
    FieldLabel,
    FieldSet,
} from \\"@/registry/ui/field\\";

const formSchema = ArraySchema;

export function ArrayField() {
    const form = useForm({
        defaultValues: { \\"items\\": [{ \\"name\\": \\"\\", \\"value\\": 0 }] },
        validators: {
            onSubmit: formSchema,
        },
        onSubmit: async ({ value }) => {
            // Handle form submission
            console.log(value)
        }
    });



    return (
        <form
            onSubmit={(e) => {
                e.preventDefault()
                form.handleSubmit()
            }}
            className=\\"space-y-8\\"
        >
            <FieldGroup>

                <form.Field
                    name=\\"items\\"
                    mode=\\"array\\"
                    children={(field) => {
                        return (<FieldSet>
                            <FieldGroup>
                                {field.state.value.map((_, index) => (
                                    <div key={index} className=\\"flex w-full items-end space-x-2\\">
                                        <form.Field
                                            name={\`items[\${index}].name\`}
                                            children={(field) => {
                                                const isInvalid = field.state.meta.isTouched && !field.state.meta.isValid
                                                return (<Field data-invalid={isInvalid}>
                                                    <FieldLabel htmlFor={field.name}>Items Index Name</FieldLabel>
                                                    <Input
                                                        name={field.name}
                                                        value={field.state.value}
                                                        onBlur={field.handleBlur}
                                                        onChange={(e) => field.handleChange(e.target.value)}
                                                        aria-invalid={isInvalid}
                                                    />
                                                    {isInvalid && (
                                                        <FieldError errors={field.state.meta.errors} />
                                                    )}
                                                </Field>)
                                            }}
                                        />
                                        <form.Field
                                            name={\`items[\${index}].value\`}
                                            children={(field) => {
                                                const isInvalid = field.state.meta.isTouched && !field.state.meta.isValid
                                                return (<Field data-invalid={isInvalid}>
                                                    <FieldLabel htmlFor={field.name}>Items Index Value</FieldLabel>
                                                    <Input
                                                        type='number'
                                                        name={field.name}
                                                        value={field.state.value}
                                                        onBlur={field.handleBlur}
                                                        onChange={(e) => field.handleChange(Number(e.target.value))}
                                                        aria-invalid={isInvalid}
                                                    />
                                                    {isInvalid && (
                                                        <FieldError errors={field.state.meta.errors} />
                                                    )}
                                                </Field>)
                                            }}
                                        />

                                        <Button
                                            type=\\"button\\"
                                            size=\\"icon\\"
                                            variant=\\"ghost\\"
                                            onClick={() => field.removeValue(index)}
                                        >
                                            <XIcon className=\\"size-4\\" />
                                        </Button>
                                    </div>
                                ))}
                            </FieldGroup>
                            <Button
                                size=\\"sm\\"
                                className=\\"mt-2\\"
                                type=\\"button\\"
                                onClick={() => field.pushValue({ \\"name\\": \\"\\", \\"value\\": 0 })}
                            >
                                <PlusIcon className=\\"size-4\\" />
                                <span className=\\"ml-2\\">Add Item</span>
                            </Button>
                        </FieldSet>
                        )
                    }}
                />


            </FieldGroup>
            <Button type=\\"submit\\">Submit</Button>
        </form>
    )
}
"
`;

exports[`Comprehensive Code Generation Tests > @tanstack/react-form > should generate form for boolean field 1`] = `
"\\"use client\\";

import { useForm } from \\"@tanstack/react-form\\"
import { BooleanSchema } from \\"./schemas\\";
import { Checkbox } from '@/registry/ui/checkbox';
import { Button } from \\"@/registry/ui/button\\";
import {
    Field,
    FieldError,
    FieldGroup,
    FieldLabel,
    FieldSet,
} from \\"@/registry/ui/field\\";

const formSchema = BooleanSchema;

export function BooleanField() {
    const form = useForm({
        defaultValues: { \\"isActive\\": false },
        validators: {
            onSubmit: formSchema,
        },
        onSubmit: async ({ value }) => {
            // Handle form submission
            console.log(value)
        }
    });



    return (
        <form
            onSubmit={(e) => {
                e.preventDefault()
                form.handleSubmit()
            }}
            className=\\"space-y-8\\"
        >
            <FieldGroup>
                <form.Field
                    name=\\"isActive\\"
                    children={(field) => {
                        const isInvalid = field.state.meta.isTouched && !field.state.meta.isValid
                        return (<Field data-invalid={isInvalid}>
                            <FieldLabel htmlFor={field.name}>Is Active</FieldLabel>
                            <Checkbox name={field.name} checked={field.state.value} onCheckedChange={field.handleChange} />
                            {isInvalid && (
                                <FieldError errors={field.state.meta.errors} />
                            )}
                        </Field>)
                    }}
                />

            </FieldGroup>
            <Button type=\\"submit\\">Submit</Button>
        </form>
    )
}
"
`;

exports[`Comprehensive Code Generation Tests > @tanstack/react-form > should generate form for complex schema 1`] = `
"\\"use client\\";

