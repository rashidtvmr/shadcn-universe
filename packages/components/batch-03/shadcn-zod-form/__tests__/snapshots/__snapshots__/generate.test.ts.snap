    Field,
    FieldError,
    FieldGroup,
    FieldLabel,
    FieldSet,
} from \\"@/registry/ui/field\\";

const formSchema = ComplexSchema;

export function ComplexForm() {
    const form = useForm({
        defaultValues: { \\"title\\": \\"\\", \\"category\\": \\"\\", \\"tags\\": [\\"\\"], \\"author\\": { \\"name\\": \\"\\", \\"email\\": \\"\\" }, \\"metadata\\": [{ \\"key\\": \\"\\", \\"value\\": \\"\\", \\"type\\": \\"\\" }] },
        validators: {
            onSubmit: formSchema,
