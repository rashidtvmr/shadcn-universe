        onSubmit: async ({ value }) => {
            // Handle form submission
            console.log(value)
        }
    });



    return (
        <form
            onSubmit={(e) => {
                e.preventDefault()
                form.handleSubmit()
            }}
            className=\\"space-y-8\\"
        >
            <FieldGroup>
                <form.Field
                    name=\\"title\\"
                    children={(field) => {
                        const isInvalid = field.state.meta.isTouched && !field.state.meta.isValid
                        return (<Field data-invalid={isInvalid}>
                            <FieldLabel htmlFor={field.name}>Title</FieldLabel>
